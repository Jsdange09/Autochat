# ════════════════════════════════════════════════════════════════
#  AEGIS-AUTOCHAT — Environment Variables Template
#  1. Copy this file:   cp .env.example .env
#  2. Fill in YOUR values below
#  3. NEVER commit .env to GitHub (already in .gitignore)
# ════════════════════════════════════════════════════════════════

# ── WEIGHTS & BIASES ─────────────────────────────────────────────
# Get from: https://wandb.ai/authorize  (free account)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=aegis-autochat

# ── ARIZE AI ─────────────────────────────────────────────────────
# Get from: https://app.arize.com → Settings → API Keys  (free account)
ARIZE_API_KEY=your_arize_api_key_here
ARIZE_SPACE_ID=your_arize_space_id_here

# ── SYSTEM CONFIG ────────────────────────────────────────────────
# Responses below this score trigger the self-healing pipeline
CONFIDENCE_THRESHOLD=0.65
